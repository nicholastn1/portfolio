<% content_for :title, "#{_('Blog')} — Nicholas Nogueira" %>
<% content_for :description, _("Field notes on software development, architecture, optimization, and AI-augmented engineering.") %>

<%= render Components::Layout::Header.new(personal_info: PersonalInfo.instance) %>

<main class="pt-12 pb-16">
  <div class="max-w-[1200px] mx-auto px-6 md:px-10">
    <%# Section header %>
    <div class="flex items-end justify-between gap-4 pb-5 mb-10 border-b border-ink flex-wrap">
      <div>
        <div class="section-id mb-2">§06</div>
        <h1 class="font-display text-ink display-wide leading-none"
            style="font-size: clamp(2.25rem, 4.8vw, 3.5rem); font-weight: 600;">
          <%= _("Blog") %>
        </h1>
      </div>
      <span class="mono-id text-ink-mute">
        <%= @posts.respond_to?(:total_count) ? @posts.total_count : @posts.length %> / <%= _("entries") %>
      </span>
    </div>

    <%# Lede %>
    <div class="grid grid-cols-12 gap-x-6 mb-10">
      <div class="col-span-12 md:col-span-9">
        <p class="font-display text-ink-soft text-[1.1rem] md:text-[1.25rem] leading-[1.5] max-w-[58ch]"
           style="font-variation-settings: 'wdth' 100, 'opsz' 32;">
          <%= _("Field notes on software development, architecture, optimization, and AI-augmented engineering.") %>
        </p>
      </div>
    </div>

    <%# Category filters as inline taxonomy %>
    <div class="grid grid-cols-12 gap-x-6 mb-10">
      <div class="col-span-12 md:col-span-3">
        <span class="mono-id text-ink-mute"><%= _("Filter") %></span>
      </div>
      <div class="col-span-12 md:col-span-9 mt-2 md:mt-0 flex flex-wrap items-baseline gap-x-4 gap-y-2">
        <%= link_to _("All"), posts_path,
          class: "mono-id transition-colors #{params[:category].blank? ? 'text-signal' : 'text-ink-mute hover:text-signal'}" %>
        <% %w[tech carreira].each do |cat| %>
          <span class="text-rule">/</span>
          <%= link_to cat.upcase, posts_path(category: cat),
            class: "mono-id transition-colors #{params[:category] == cat ? 'text-signal' : 'text-ink-mute hover:text-signal'}" %>
        <% end %>
      </div>
    </div>

    <%# Posts list %>
    <% if @posts.any? %>
      <div>
        <% @posts.each do |post| %>
          <%= render Components::Blog::PostCard.new(post: post) %>
        <% end %>

        <% if @pagy.pages > 1 %>
          <div class="mt-12 pt-8 border-t border-rule flex justify-center">
            <%== pagy_nav(@pagy) %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="py-16 max-w-[60ch]">
        <p class="font-display text-ink text-[1.4rem] mb-2"
           style="font-variation-settings: 'wdth' 100, 'opsz' 32; font-weight: 500;">
          <%= _("No entries yet.") %>
        </p>
        <p class="mono-id text-ink-mute"><%= _("New posts coming soon.") %></p>
      </div>
    <% end %>
  </div>
</main>

<%= render Components::Layout::Footer.new(personal_info: PersonalInfo.instance) %>
