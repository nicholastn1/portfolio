<% content_for :title, "#{@post.title} — Nicholas Nogueira" %>
<% content_for :description, @post.description.presence || @post.title %>
<% content_for :og_type, "article" %>

<%= render Components::Layout::Header.new(personal_info: PersonalInfo.instance) %>

<main class="pt-10 pb-16">
  <article class="max-w-[1200px] mx-auto px-6 md:px-10">
    <%# Back link %>
    <div class="mb-8">
      <%= link_to posts_path,
            class: "mono-id text-ink-mute hover:text-signal transition-colors inline-flex items-baseline gap-2" do %>
        <span>←</span><span><%= _("Back to blog") %></span>
      <% end %>
    </div>

    <%# Article header %>
    <header class="grid grid-cols-12 gap-x-6 mb-12 pb-8 border-b border-rule">
      <div class="col-span-12 md:col-span-3 mb-5 md:mb-0">
        <div class="mono-id text-ink-mute mb-2 flex flex-wrap gap-x-3 gap-y-1">
          <% if @post.category.present? %>
            <span class="text-signal"><%= @post.category.to_s.upcase %></span>
            <span class="text-rule">/</span>
          <% end %>
          <span><%= @post.published_at&.strftime("%Y-%m-%d") %></span>
        </div>
        <% if @post.reading_time %>
          <div class="mono-id text-ink-mute">
            <%= @post.reading_time %> <%= _("min read") %>
          </div>
        <% end %>
      </div>

      <div class="col-span-12 md:col-span-9">
        <h1 class="font-display text-ink leading-[1.05] mb-5"
            style="font-size: clamp(1.85rem, 4.2vw, 3.25rem); font-variation-settings: 'wdth' 100, 'opsz' 96; font-weight: 600;">
          <%= @post.title %>
        </h1>
        <% if @post.description.present? %>
          <p class="text-ink-soft text-[1.1rem] md:text-[1.2rem] leading-[1.5] max-w-[60ch]"
             style="font-variation-settings: 'wdth' 100, 'opsz' 32;">
            <%= @post.description %>
          </p>
        <% end %>

        <% if @post.tags.present? %>
          <div class="mt-5 flex flex-wrap items-center gap-1.5">
            <% @post.tags.each do |tag| %>
              <span class="chip"><%= tag %></span>
            <% end %>
          </div>
        <% end %>
      </div>
    </header>

    <%# Cover image %>
    <% if @post.cover_image.attached? %>
      <figure class="grid grid-cols-12 gap-x-6 mb-14">
        <div class="col-span-12 md:col-start-3 md:col-span-9">
          <div class="border border-rule overflow-hidden">
            <%= image_tag @post.cover_image,
                  alt: @post.title,
                  loading: "eager",
                  class: "w-full h-auto block" %>
          </div>
          <figcaption class="mono-id text-ink-mute mt-2"><%= _("Figure 01") %></figcaption>
        </div>
      </figure>
    <% end %>

    <%# Body %>
    <div class="grid grid-cols-12 gap-x-6">
      <div class="col-span-12 md:col-start-3 md:col-span-8 lg:col-span-7 editorial-prose">
        <%= @post.body %>
      </div>
    </div>

    <%# Closing strip %>
    <div class="mt-16 pt-6 border-t border-rule flex items-center justify-between mono-id text-ink-mute">
      <span>END / <%= @post.published_at&.strftime("%Y-%m-%d") %></span>
      <%= link_to _("Back to blog") + " →", posts_path,
            class: "text-ink-mute hover:text-signal transition-colors" %>
    </div>
  </article>
</main>

<%= render Components::Layout::Footer.new(personal_info: PersonalInfo.instance) %>
