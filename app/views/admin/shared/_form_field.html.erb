<div class="mb-4">
  <label for="<%= field_id %>" class="block text-sm text-ink-mute mb-1"><%= label %></label>
  <% case type %>
  <% when :text %>
    <input type="text" name="<%= field_name %>" id="<%= field_id %>" value="<%= value %>"
           class="w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all"
           <%= "required" if required %>>
  <% when :textarea %>
    <textarea name="<%= field_name %>" id="<%= field_id %>" rows="<%= rows || 4 %>"
              class="w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all"
              <%= "required" if required %>><%= value %></textarea>
  <% when :date %>
    <input type="date" name="<%= field_name %>" id="<%= field_id %>" value="<%= value %>"
           class="w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all"
           <%= "required" if required %>>
  <% when :select %>
    <select name="<%= field_name %>" id="<%= field_id %>"
            class="w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all"
            <%= "required" if required %>>
      <option value="">Selecione...</option>
      <% options.each do |opt| %>
        <option value="<%= opt %>" <%= "selected" if value == opt %>><%= opt.capitalize %></option>
      <% end %>
    </select>
  <% when :checkbox %>
    <input type="checkbox" name="<%= field_name %>" id="<%= field_id %>" value="1"
           class="rounded border-rule bg-paper-deep text-signal focus:ring-signal/50"
           <%= "checked" if value %>>
  <% when :number %>
    <input type="number" name="<%= field_name %>" id="<%= field_id %>" value="<%= value %>"
           class="w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all"
           <%= "required" if required %>>
  <% end %>
</div>
