<%= form_with model: [:admin, post], class: "space-y-4 max-w-2xl" do |form| %>
  <% if post.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 p-4 mb-4">
      <% post.errors.full_messages.each do |msg| %>
        <p class="text-red-400 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :title_pt, "Titulo (PT)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :title_pt, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :title_en, "Titulo (EN)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :title_en, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :description_pt, "Descricao (PT)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_area :description_pt, rows: 3, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :description_en, "Descricao (EN)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_area :description_en, rows: 3, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :slug, "Slug", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :slug, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :category, "Categoria", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.select :category, options_for_select([["Tech", "tech"], ["Carreira", "carreira"]], post.category), { include_blank: "Selecione..." }, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :tags, "Tags (separadas por virgula)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :tags, value: post.tags&.join(", "), class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="flex items-center gap-3">
    <div class="flex items-center gap-2">
      <%= form.check_box :published, class: "rounded border-rule bg-paper-deep text-signal focus:ring-signal/50" %>
      <%= form.label :published, "Publicado", class: "text-sm text-ink-mute" %>
    </div>
  </div>

  <div>
    <%= form.label :published_at, "Data de Publicacao", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.datetime_local_field :published_at, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :body, "Conteudo", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.rich_text_area :body %>
  </div>

  <div>
    <%= form.label :cover_image, "Imagem de Capa", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.file_field :cover_image, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all file:mr-4 file:file:border-0 file:bg-paper-deep file:px-4 file:py-2 file:text-sm file:text-ink" %>
    <% if post.persisted? && post.cover_image.attached? %>
      <p class="text-xs text-ink-mute mt-1">Imagem atual: <%= post.cover_image.filename %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= form.submit post.persisted? ? "Atualizar" : "Criar", class: "px-6 py-2.5 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity cursor-pointer" %>
    <%= link_to "Cancelar", admin_posts_path, class: "px-6 py-2.5 bg-paper-deep text-ink text-sm border border-rule hover:bg-paper-deep transition-all" %>
  </div>
<% end %>
