<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-ink">Links Sociais</h1>
  <%= link_to "Novo Link", new_admin_social_link_path, class: "px-4 py-2 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity" %>
</div>

<table class="w-full">
  <thead>
    <tr>
      <th class="text-left text-xs text-ink-mute uppercase tracking-wider pb-3 border-b border-rule">Plataforma</th>
      <th class="text-left text-xs text-ink-mute uppercase tracking-wider pb-3 border-b border-rule">Label</th>
      <th class="text-left text-xs text-ink-mute uppercase tracking-wider pb-3 border-b border-rule">URL</th>
      <th class="text-left text-xs text-ink-mute uppercase tracking-wider pb-3 border-b border-rule"></th>
    </tr>
  </thead>
  <tbody>
    <% @social_links.each do |social_link| %>
      <tr>
        <td class="py-3 text-sm text-ink-mute border-b border-rule">
          <span class="px-2 py-0.5 rounded-full text-xs bg-paper-deep border border-rule"><%= social_link.platform&.capitalize %></span>
        </td>
        <td class="py-3 text-sm text-ink-mute border-b border-rule"><%= social_link.label %></td>
        <td class="py-3 text-sm text-ink-mute border-b border-rule"><%= truncate(social_link.url, length: 40) %></td>
        <td class="py-3 text-sm border-b border-rule text-right">
          <div class="flex items-center justify-end gap-3">
            <%= link_to "Editar", edit_admin_social_link_path(social_link), class: "text-signal hover:underline text-sm" %>
            <%= button_to "Excluir", admin_social_link_path(social_link), method: :delete, form: { class: "inline" }, data: { turbo_confirm: "Tem certeza?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @pagy.pages > 1 %>
  <div class="mt-8">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
