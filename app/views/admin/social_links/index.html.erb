<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-white">Links Sociais</h1>
  <%= link_to "Novo Link", new_admin_social_link_path, class: "px-4 py-2 rounded-lg bg-accent-green text-bg-dark text-sm font-medium hover:opacity-90 transition-opacity" %>
</div>

<table class="w-full">
  <thead>
    <tr>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Plataforma</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Label</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">URL</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5"></th>
    </tr>
  </thead>
  <tbody>
    <% @social_links.each do |social_link| %>
      <tr>
        <td class="py-3 text-sm text-text-muted border-b border-white/5">
          <span class="px-2 py-0.5 rounded-full text-xs bg-white/5 border border-white/10"><%= social_link.platform&.capitalize %></span>
        </td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= social_link.label %></td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= truncate(social_link.url, length: 40) %></td>
        <td class="py-3 text-sm border-b border-white/5 text-right space-x-3">
          <%= link_to "Editar", edit_admin_social_link_path(social_link), class: "text-accent-green hover:underline text-sm" %>
          <%= button_to "Excluir", admin_social_link_path(social_link), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @pagy.pages > 1 %>
  <div class="mt-8">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
