<%= form_with model: [:admin, social_link], class: "space-y-4 max-w-2xl" do |form| %>
  <% if social_link.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 p-4 mb-4">
      <% social_link.errors.full_messages.each do |msg| %>
        <p class="text-red-400 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :platform, "Plataforma", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.select :platform, options_for_select([["GitHub", "github"], ["LinkedIn", "linkedin"], ["Instagram", "instagram"], ["WhatsApp", "whatsapp"], ["Email", "email"]], social_link.platform), { include_blank: "Selecione..." }, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :url, "URL", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :url, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :label, "Label", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :label, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :icon, "Icone", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :icon, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :position, "Posicao", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.number_field :position, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= form.submit social_link.persisted? ? "Atualizar" : "Criar", class: "px-6 py-2.5 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity cursor-pointer" %>
    <%= link_to "Cancelar", admin_social_links_path, class: "px-6 py-2.5 bg-paper-deep text-ink text-sm border border-rule hover:bg-paper-deep transition-all" %>
  </div>
<% end %>
