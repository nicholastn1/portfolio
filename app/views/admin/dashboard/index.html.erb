<h1 class="text-2xl font-bold text-white mb-8">Dashboard</h1>

<%# Stats grid %>
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 mb-12">
  <% @stats.each do |key, count| %>
    <div class="bg-white/[0.02] border border-white/5 rounded-xl p-5">
      <p class="text-text-muted text-xs uppercase tracking-wider mb-1"><%= key.to_s.humanize %></p>
      <p class="text-2xl font-bold text-white"><%= count %></p>
    </div>
  <% end %>
</div>

<%# Recent posts %>
<div class="bg-white/[0.02] border border-white/5 rounded-xl p-6">
  <h2 class="text-lg font-semibold text-white mb-4">Posts Recentes</h2>
  <% if @recent_posts.any? %>
    <div class="space-y-3">
      <% @recent_posts.each do |post| %>
        <div class="flex items-center justify-between py-2 border-b border-white/5 last:border-0">
          <div>
            <p class="text-sm text-white"><%= post.title_pt %></p>
            <p class="text-xs text-text-muted">
              <%= post.published? ? "Publicado" : "Rascunho" %> &middot;
              <%= post.category&.capitalize %>
            </p>
          </div>
          <%= link_to "Editar", edit_admin_post_path(post), class: "text-xs text-accent-green hover:underline" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-text-muted text-sm">Nenhum post criado ainda.</p>
  <% end %>
</div>

<%# Quick links %>
<div class="mt-8 flex flex-wrap gap-3">
  <%= link_to "Novo Post", new_admin_post_path, class: "px-4 py-2 rounded-lg bg-accent-green text-bg-dark text-sm font-medium hover:opacity-90 transition-opacity" %>
  <%= link_to "Ver Site", root_path, target: "_blank", class: "px-4 py-2 rounded-lg bg-white/5 text-white text-sm border border-white/10 hover:bg-white/10 transition-all" %>
</div>
