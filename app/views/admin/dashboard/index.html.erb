<%# Header %>
<div class="flex items-end justify-between gap-4 pb-5 mb-10 border-b border-ink flex-wrap">
  <div>
    <div class="font-mono text-[0.7rem] tracking-[0.14em] text-signal uppercase mb-2">§00 / Overview</div>
    <h1 class="font-display text-ink leading-none -tracking-[0.02em]" style="font-size: clamp(2rem, 4vw, 2.75rem); font-weight: 600; font-variation-settings: 'wdth' 95;">
      Dashboard
    </h1>
  </div>
  <div class="flex items-center gap-3">
    <%= link_to "+ New post", new_admin_post_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-ink text-paper font-mono text-[0.7rem] tracking-[0.14em] uppercase hover:bg-signal transition-colors" %>
    <%= link_to "View site ↗", root_path, target: "_blank", class: "inline-flex items-center gap-2 px-4 py-2 border border-rule text-ink font-mono text-[0.7rem] tracking-[0.14em] uppercase hover:border-ink hover:text-signal transition-colors" %>
  </div>
</div>

<%# Stats grid %>
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-px bg-rule mb-12 border border-rule">
  <% @stats.each do |key, count| %>
    <div class="bg-paper p-5">
      <p class="font-mono text-[0.65rem] tracking-[0.18em] uppercase text-ink-mute mb-2"><%= key.to_s.humanize %></p>
      <p class="font-display text-ink text-[2rem] leading-none" style="font-weight: 600; font-variation-settings: 'wdth' 95; font-variant-numeric: tabular-nums;"><%= count %></p>
    </div>
  <% end %>
</div>

<%# Recent posts %>
<div class="grid grid-cols-12 gap-x-6 mb-12">
  <div class="col-span-12 md:col-span-3 mb-3 md:mb-0">
    <div class="font-mono text-[0.7rem] tracking-[0.14em] text-signal mb-1">RECENT</div>
    <h2 class="font-display text-ink text-[1.15rem] leading-tight" style="font-weight: 600;">Latest posts</h2>
  </div>
  <div class="col-span-12 md:col-span-9">
    <% if @recent_posts.any? %>
      <div class="border-t border-rule">
        <% @recent_posts.each do |post| %>
          <div class="grid grid-cols-12 gap-x-4 items-baseline py-3 border-b border-rule">
            <div class="col-span-12 sm:col-span-7">
              <p class="font-display text-ink text-[1rem] leading-tight" style="font-weight: 500;"><%= post.title_pt %></p>
            </div>
            <div class="col-span-6 sm:col-span-3 font-mono text-[0.7rem] uppercase tracking-[0.1em]">
              <span class="<%= post.published? ? 'text-signal' : 'text-ink-mute' %>"><%= post.published? ? "PUBLISHED" : "DRAFT" %></span>
              <% if post.category.present? %>
                <span class="text-rule mx-1">/</span>
                <span class="text-ink-mute"><%= post.category.upcase %></span>
              <% end %>
            </div>
            <div class="col-span-6 sm:col-span-2 text-right">
              <%= link_to "edit →", edit_admin_post_path(post), class: "font-mono text-[0.7rem] uppercase tracking-[0.1em] text-ink-mute hover:text-signal transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-ink-mute text-sm py-3">No posts yet.</p>
    <% end %>
  </div>
</div>
