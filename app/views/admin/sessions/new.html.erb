<div class="min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-white">
        Admin<span class="text-accent-green">.</span>
      </h1>
      <p class="text-text-muted text-sm mt-2">Faça login para acessar o painel</p>
    </div>

    <%= form_with url: admin_login_path, method: :post, class: "space-y-4" do |f| %>
      <div>
        <label for="email" class="block text-sm text-text-muted mb-1">Email</label>
        <input type="email" name="email" id="email" required autofocus
               class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all">
      </div>
      <div>
        <label for="password" class="block text-sm text-text-muted mb-1">Senha</label>
        <input type="password" name="password" id="password" required
               class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all">
      </div>
      <button type="submit" class="w-full py-2.5 rounded-lg bg-gradient-primary text-white text-sm font-medium hover:opacity-90 transition-opacity">
        Entrar
      </button>
    <% end %>

    <div class="text-center mt-6">
      <a href="/" class="text-text-muted text-xs hover:text-white transition-colors">Voltar ao site</a>
    </div>
  </div>
</div>
