<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-ink">Informacoes Pessoais</h1>
  <%= link_to "Editar", edit_admin_personal_info_path, class: "px-4 py-2 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity" %>
</div>

<div class="max-w-2xl space-y-6">
  <% if @personal_info.profile_image.attached? %>
    <div>
      <%= image_tag @personal_info.profile_image, class: "w-24 h-24 rounded-full object-cover" %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-6">
    <div>
      <p class="text-xs text-ink-mute uppercase tracking-wider mb-1">Nome</p>
      <p class="text-sm text-ink"><%= @personal_info.name %></p>
    </div>

    <div>
      <p class="text-xs text-ink-mute uppercase tracking-wider mb-1">Titulo</p>
      <p class="text-sm text-ink"><%= @personal_info.title %></p>
    </div>

    <div>
      <p class="text-xs text-ink-mute uppercase tracking-wider mb-1">Localizacao</p>
      <p class="text-sm text-ink"><%= @personal_info.location %></p>
    </div>

    <div>
      <p class="text-xs text-ink-mute uppercase tracking-wider mb-1">Email</p>
      <p class="text-sm text-ink"><%= @personal_info.email %></p>
    </div>

    <div>
      <p class="text-xs text-ink-mute uppercase tracking-wider mb-1">Telefone</p>
      <p class="text-sm text-ink"><%= @personal_info.phone %></p>
    </div>
  </div>

  <div class="border-t border-rule pt-6">
    <p class="text-xs text-ink-mute uppercase tracking-wider mb-2">Mensagem WhatsApp</p>
    <p class="text-sm text-ink-mute"><%= @personal_info.whatsapp_message %></p>
  </div>

  <div class="border-t border-rule pt-6">
    <p class="text-xs text-ink-mute uppercase tracking-wider mb-2">Tagline / hero (PT)</p>
    <p class="text-sm text-ink-mute"><%= @personal_info.tagline_pt.presence || "(usando texto padrão)" %></p>
  </div>

  <div class="border-t border-rule pt-6">
    <p class="text-xs text-ink-mute uppercase tracking-wider mb-2">Tagline / hero (EN)</p>
    <p class="text-sm text-ink-mute"><%= @personal_info.tagline_en.presence || "(using default text)" %></p>
  </div>

  <div class="border-t border-rule pt-6">
    <p class="text-xs text-ink-mute uppercase tracking-wider mb-2">Bio (PT)</p>
    <p class="text-sm text-ink-mute whitespace-pre-line"><%= @personal_info.bio_pt&.join("\n\n") %></p>
  </div>

  <div class="border-t border-rule pt-6">
    <p class="text-xs text-ink-mute uppercase tracking-wider mb-2">Bio (EN)</p>
    <p class="text-sm text-ink-mute whitespace-pre-line"><%= @personal_info.bio_en&.join("\n\n") %></p>
  </div>

  <div class="border-t border-rule pt-6">
    <p class="text-xs text-ink-mute uppercase tracking-wider mb-2">Texto do Footer (PT)</p>
    <p class="text-sm text-ink-mute"><%= @personal_info.footer_text_pt %></p>
  </div>

  <div class="border-t border-rule pt-6">
    <p class="text-xs text-ink-mute uppercase tracking-wider mb-2">Texto do Footer (EN)</p>
    <p class="text-sm text-ink-mute"><%= @personal_info.footer_text_en %></p>
  </div>
</div>
