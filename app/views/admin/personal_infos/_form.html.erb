<%= form_with model: [:admin, @personal_info], url: admin_personal_info_path, class: "space-y-4 max-w-2xl" do |form| %>
  <% if @personal_info.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 rounded-lg p-4 mb-4">
      <% @personal_info.errors.full_messages.each do |msg| %>
        <p class="text-red-400 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Nome", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_field :name, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :title, "Titulo", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_field :title, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :location, "Localizacao", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_field :location, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all" %>
  </div>

  <div>
    <%= form.label :email, "Email", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_field :email, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all" %>
  </div>

  <div>
    <%= form.label :phone, "Telefone", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_field :phone, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all" %>
  </div>

  <div>
    <%= form.label :whatsapp_message, "Mensagem WhatsApp", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_area :whatsapp_message, rows: 3, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all" %>
  </div>

  <div>
    <%= form.label :bio_pt, "Bio (PT) - paragrafos separados por linha em branco", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_area :bio_pt, value: @personal_info.bio_pt&.join("\n\n"), rows: 6, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all" %>
  </div>

  <div>
    <%= form.label :bio_en, "Bio (EN) - paragrafos separados por linha em branco", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_area :bio_en, value: @personal_info.bio_en&.join("\n\n"), rows: 6, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all" %>
  </div>

  <div>
    <%= form.label :footer_text_pt, "Texto do Footer (PT)", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_area :footer_text_pt, rows: 3, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all" %>
  </div>

  <div>
    <%= form.label :footer_text_en, "Texto do Footer (EN)", class: "block text-sm text-text-muted mb-1" %>
    <%= form.text_area :footer_text_en, rows: 3, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all" %>
  </div>

  <div>
    <%= form.label :profile_image, "Imagem de Perfil", class: "block text-sm text-text-muted mb-1" %>
    <%= form.file_field :profile_image, class: "w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white text-sm focus:outline-none focus:border-accent-green/50 focus:ring-1 focus:ring-accent-green/50 transition-all file:mr-4 file:rounded-lg file:border-0 file:bg-white/10 file:px-4 file:py-2 file:text-sm file:text-white" %>
    <% if @personal_info.persisted? && @personal_info.profile_image.attached? %>
      <p class="text-xs text-text-muted mt-1">Imagem atual: <%= @personal_info.profile_image.filename %></p>
    <% end %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= form.submit "Atualizar", class: "px-6 py-2.5 rounded-lg bg-accent-green text-bg-dark text-sm font-medium hover:opacity-90 transition-opacity cursor-pointer" %>
    <%= link_to "Cancelar", admin_personal_info_path, class: "px-6 py-2.5 rounded-lg bg-white/5 text-white text-sm border border-white/10 hover:bg-white/10 transition-all" %>
  </div>
<% end %>
