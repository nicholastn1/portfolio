<%= form_with model: [:admin, project], class: "space-y-4 max-w-2xl" do |form| %>
  <% if project.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 p-4 mb-4">
      <% project.errors.full_messages.each do |msg| %>
        <p class="text-red-400 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Nome", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :name, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :description_pt, "Descricao (PT)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_area :description_pt, rows: 4, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :description_en, "Descricao (EN)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_area :description_en, rows: 4, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= form.label :started_at, "Inicio", class: "block text-sm text-ink-mute mb-1" %>
      <%= form.date_field :started_at, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
    </div>
    <div>
      <%= form.label :ended_at, "Fim", class: "block text-sm text-ink-mute mb-1" %>
      <%= form.date_field :ended_at, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
    </div>
  </div>

  <div>
    <%= form.label :technologies, "Tecnologias (separadas por virgula)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :technologies, value: project.technologies&.join(", "), class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :url, "URL", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :url, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :github_url, "GitHub URL", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :github_url, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :image, "Imagem", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.file_field :image, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all file:mr-4 file:file:border-0 file:bg-paper-deep file:px-4 file:py-2 file:text-sm file:text-ink" %>
    <% if project.persisted? && project.image.attached? %>
      <p class="text-xs text-ink-mute mt-1">Imagem atual: <%= project.image.filename %></p>
    <% end %>
  </div>

  <div>
    <%= form.label :position, "Posicao", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.number_field :position, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= form.submit project.persisted? ? "Atualizar" : "Criar", class: "px-6 py-2.5 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity cursor-pointer" %>
    <%= link_to "Cancelar", admin_projects_path, class: "px-6 py-2.5 bg-paper-deep text-ink text-sm border border-rule hover:bg-paper-deep transition-all" %>
  </div>
<% end %>
