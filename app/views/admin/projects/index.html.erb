<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-white">Projetos</h1>
  <%= link_to "Novo Projeto", new_admin_project_path, class: "px-4 py-2 rounded-lg bg-accent-green text-bg-dark text-sm font-medium hover:opacity-90 transition-opacity" %>
</div>

<table class="w-full">
  <thead>
    <tr>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Nome</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Tecnologias</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5"></th>
    </tr>
  </thead>
  <tbody>
    <% @projects.each do |project| %>
      <tr>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= project.name %></td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= truncate(project.technologies&.join(", "), length: 60) %></td>
        <td class="py-3 text-sm border-b border-white/5 text-right">
          <div class="flex items-center justify-end gap-3">
            <%= link_to "Editar", edit_admin_project_path(project), class: "text-accent-green hover:underline text-sm" %>
            <%= button_to "Excluir", admin_project_path(project), method: :delete, form: { class: "inline" }, data: { turbo_confirm: "Tem certeza?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @pagy.pages > 1 %>
  <div class="mt-8">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
