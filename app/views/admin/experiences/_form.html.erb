<%= form_with model: [:admin, experience], class: "space-y-4 max-w-2xl" do |form| %>
  <% if experience.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 p-4 mb-4">
      <% experience.errors.full_messages.each do |msg| %>
        <p class="text-red-400 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :company, "Empresa", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :company, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :role_pt, "Cargo (PT)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :role_pt, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :role_en, "Cargo (EN)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :role_en, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :company_url, "URL da Empresa", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :company_url, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= form.label :started_at, "Inicio", class: "block text-sm text-ink-mute mb-1" %>
      <%= form.date_field :started_at, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
    </div>
    <div>
      <%= form.label :ended_at, "Fim", class: "block text-sm text-ink-mute mb-1" %>
      <%= form.date_field :ended_at, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
    </div>
  </div>

  <div>
    <%= form.label :description_pt, "Descricao (PT)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_area :description_pt, rows: 4, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :description_en, "Descricao (EN)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_area :description_en, rows: 4, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :achievements_pt, "Conquistas (PT) - uma por linha", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_area :achievements_pt, value: experience.achievements_pt&.join("\n"), rows: 4, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :achievements_en, "Conquistas (EN) - uma por linha", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_area :achievements_en, value: experience.achievements_en&.join("\n"), rows: 4, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :technologies, "Tecnologias (separadas por virgula)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :technologies, value: experience.technologies&.join(", "), class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :position, "Posicao", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.number_field :position, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= form.submit experience.persisted? ? "Atualizar" : "Criar", class: "px-6 py-2.5 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity cursor-pointer" %>
    <%= link_to "Cancelar", admin_experiences_path, class: "px-6 py-2.5 bg-paper-deep text-ink text-sm border border-rule hover:bg-paper-deep transition-all" %>
  </div>
<% end %>
