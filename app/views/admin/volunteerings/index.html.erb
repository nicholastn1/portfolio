<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-white">Voluntariado</h1>
  <%= link_to "Novo Voluntariado", new_admin_volunteering_path, class: "px-4 py-2 rounded-lg bg-accent-green text-bg-dark text-sm font-medium hover:opacity-90 transition-opacity" %>
</div>

<table class="w-full">
  <thead>
    <tr>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Cargo</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Organizacao</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Periodo</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5"></th>
    </tr>
  </thead>
  <tbody>
    <% @volunteerings.each do |volunteering| %>
      <tr>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= volunteering.role_pt %></td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= volunteering.organization %></td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5">
          <%= volunteering.started_at&.strftime("%b %Y") %> - <%= volunteering.ended_at&.strftime("%b %Y") || "Atual" %>
        </td>
        <td class="py-3 text-sm border-b border-white/5 text-right space-x-3">
          <%= link_to "Editar", edit_admin_volunteering_path(volunteering), class: "text-accent-green hover:underline text-sm" %>
          <%= button_to "Excluir", admin_volunteering_path(volunteering), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @pagy.pages > 1 %>
  <div class="mt-8">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
