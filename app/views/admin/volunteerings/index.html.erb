<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-ink">Voluntariado</h1>
  <%= link_to "Novo Voluntariado", new_admin_volunteering_path, class: "px-4 py-2 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity" %>
</div>

<table class="w-full">
  <thead>
    <tr>
      <th class="text-left text-xs text-ink-mute uppercase tracking-wider pb-3 border-b border-rule">Cargo</th>
      <th class="text-left text-xs text-ink-mute uppercase tracking-wider pb-3 border-b border-rule">Organizacao</th>
      <th class="text-left text-xs text-ink-mute uppercase tracking-wider pb-3 border-b border-rule">Periodo</th>
      <th class="text-left text-xs text-ink-mute uppercase tracking-wider pb-3 border-b border-rule"></th>
    </tr>
  </thead>
  <tbody>
    <% @volunteerings.each do |volunteering| %>
      <tr>
        <td class="py-3 text-sm text-ink-mute border-b border-rule"><%= volunteering.role_pt %></td>
        <td class="py-3 text-sm text-ink-mute border-b border-rule"><%= volunteering.organization %></td>
        <td class="py-3 text-sm text-ink-mute border-b border-rule">
          <%= volunteering.started_at&.strftime("%b %Y") %> - <%= volunteering.ended_at&.strftime("%b %Y") || "Atual" %>
        </td>
        <td class="py-3 text-sm border-b border-rule text-right">
          <div class="flex items-center justify-end gap-3">
            <%= link_to "Editar", edit_admin_volunteering_path(volunteering), class: "text-signal hover:underline text-sm" %>
            <%= button_to "Excluir", admin_volunteering_path(volunteering), method: :delete, form: { class: "inline" }, data: { turbo_confirm: "Tem certeza?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @pagy.pages > 1 %>
  <div class="mt-8">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
