<%= form_with model: [:admin, volunteering], class: "space-y-4 max-w-2xl" do |form| %>
  <% if volunteering.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 p-4 mb-4">
      <% volunteering.errors.full_messages.each do |msg| %>
        <p class="text-red-400 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :role_pt, "Cargo (PT)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :role_pt, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :role_en, "Cargo (EN)", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :role_en, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :organization, "Organizacao", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :organization, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= form.label :started_at, "Inicio", class: "block text-sm text-ink-mute mb-1" %>
      <%= form.date_field :started_at, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
    </div>
    <div>
      <%= form.label :ended_at, "Fim", class: "block text-sm text-ink-mute mb-1" %>
      <%= form.date_field :ended_at, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
    </div>
  </div>

  <div>
    <%= form.label :position, "Posicao", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.number_field :position, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= form.submit volunteering.persisted? ? "Atualizar" : "Criar", class: "px-6 py-2.5 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity cursor-pointer" %>
    <%= link_to "Cancelar", admin_volunteerings_path, class: "px-6 py-2.5 bg-paper-deep text-ink text-sm border border-rule hover:bg-paper-deep transition-all" %>
  </div>
<% end %>
