<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-white">Idiomas</h1>
  <%= link_to "Novo Idioma", new_admin_language_path, class: "px-4 py-2 rounded-lg bg-accent-green text-bg-dark text-sm font-medium hover:opacity-90 transition-opacity" %>
</div>

<table class="w-full">
  <thead>
    <tr>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Nome</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Nivel</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Proficiencia</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5"></th>
    </tr>
  </thead>
  <tbody>
    <% @languages.each do |language| %>
      <tr>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= language.name_pt %></td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= language.level_pt %></td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= language.proficiency %></td>
        <td class="py-3 text-sm border-b border-white/5 text-right space-x-3">
          <%= link_to "Editar", edit_admin_language_path(language), class: "text-accent-green hover:underline text-sm" %>
          <%= button_to "Excluir", admin_language_path(language), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<%== pagy_nav(@pagy) %>
