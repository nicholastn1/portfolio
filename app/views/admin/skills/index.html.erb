<div class="flex items-center justify-between mb-8">
  <h1 class="text-2xl font-bold text-white">Skills</h1>
  <%= link_to "Nova Skill", new_admin_skill_path, class: "px-4 py-2 rounded-lg bg-accent-green text-bg-dark text-sm font-medium hover:opacity-90 transition-opacity" %>
</div>

<table class="w-full">
  <thead>
    <tr>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Nome</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Categoria</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Proficiencia</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5">Destaque</th>
      <th class="text-left text-xs text-text-muted uppercase tracking-wider pb-3 border-b border-white/5"></th>
    </tr>
  </thead>
  <tbody>
    <% @skills.each do |skill| %>
      <tr>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= skill.name %></td>
        <td class="py-3 text-sm border-b border-white/5">
          <span class="px-2 py-0.5 rounded-full text-xs bg-white/5 border border-white/10 text-text-muted"><%= skill.category&.capitalize %></span>
        </td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5"><%= skill.proficiency&.capitalize %></td>
        <td class="py-3 text-sm text-text-muted border-b border-white/5">
          <% if skill.featured? %>
            <span class="text-accent-green">&#10003;</span>
          <% end %>
        </td>
        <td class="py-3 text-sm border-b border-white/5 text-right">
          <div class="flex items-center justify-end gap-3">
            <%= link_to "Editar", edit_admin_skill_path(skill), class: "text-accent-green hover:underline text-sm" %>
            <%= button_to "Excluir", admin_skill_path(skill), method: :delete, form: { class: "inline" }, data: { turbo_confirm: "Tem certeza?" }, class: "text-red-400 hover:text-red-300 text-sm" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @pagy.pages > 1 %>
  <div class="mt-8">
    <%== pagy_nav(@pagy) %>
  </div>
<% end %>
