<%= form_with model: [:admin, skill], class: "space-y-4 max-w-2xl" do |form| %>
  <% if skill.errors.any? %>
    <div class="bg-red-500/10 border border-red-500/20 p-4 mb-4">
      <% skill.errors.full_messages.each do |msg| %>
        <p class="text-red-400 text-sm"><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "Nome", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.text_field :name, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all", required: true %>
  </div>

  <div>
    <%= form.label :category, "Categoria", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.select :category, options_for_select(Skill::CATEGORIES.map { |c| [c.capitalize, c] }, skill.category), { include_blank: "Selecione..." }, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div>
    <%= form.label :proficiency, "Proficiencia", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.select :proficiency, options_for_select(Skill::PROFICIENCIES.map { |p| [p.capitalize, p] }, skill.proficiency), { include_blank: "Selecione..." }, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="flex items-center gap-2">
    <%= form.check_box :featured, class: "rounded border-rule bg-paper-deep text-signal focus:ring-signal/50" %>
    <%= form.label :featured, "Destaque", class: "text-sm text-ink-mute" %>
  </div>

  <div>
    <%= form.label :position, "Posicao", class: "block text-sm text-ink-mute mb-1" %>
    <%= form.number_field :position, class: "w-full px-4 py-2.5 bg-paper-deep border border-rule text-ink text-sm focus:outline-none focus:border-signal/50 focus:ring-1 focus:ring-signal/50 transition-all" %>
  </div>

  <div class="flex items-center gap-3 pt-4">
    <%= form.submit skill.persisted? ? "Atualizar" : "Criar", class: "px-6 py-2.5 bg-signal text-paper text-sm font-medium hover:opacity-90 transition-opacity cursor-pointer" %>
    <%= link_to "Cancelar", admin_skills_path, class: "px-6 py-2.5 bg-paper-deep text-ink text-sm border border-rule hover:bg-paper-deep transition-all" %>
  </div>
<% end %>
